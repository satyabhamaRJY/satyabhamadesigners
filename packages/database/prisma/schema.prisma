datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?   @db.Text
  image       String?   // URL to S3 or Supabase Storage
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("categories")
}

model Product {
  id            String      @id @default(uuid())
  name          String
  slug          String      @unique
  description   String      @db.Text // Rich Text Description
  price         Decimal     @db.Decimal(10, 2)
  discountPrice Decimal?    @db.Decimal(10, 2)
  images        String[]    // Array of URLs (Supabase storage/S3)
  weight        Float       // Weight in grams (for Shiprocket)
  length        Float       // Package length in cm (for Shiprocket)
  width         Float       // Package width in cm (for Shiprocket)
  height        Float       // Package height in cm (for Shiprocket)
  sku           String      @unique
  barcode       String?     @unique
  stock         Int         @default(0)
  categoryId    String
  category      Category    @relation(fields: [categoryId], references: [id])
  orderItems    OrderItem[]
  trousseauItems TrousseauItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("products")
}

model Customer {
  id        String   @id // Maps to Supabase auth.users UUID
  phone     String   @unique // Verified phone number for OTP login
  name          String?
  email         String?
  orders        Order[]
  trousseauBoards TrousseauBoard[]
  consultations StylingConsultation[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("customers")
}

model Order {
  id                 String        @id @default(uuid())
  orderNumber        String        @unique // e.g. LUX-10001
  source             String        @default("ONLINE") // ONLINE or POS
  customerId         String?
  customer           Customer?     @relation(fields: [customerId], references: [id])
  status             OrderStatus   @default(PENDING)
  totalAmount        Decimal       @db.Decimal(10, 2)
  shippingAmount     Decimal       @db.Decimal(10, 2)
  discountAmount     Decimal       @db.Decimal(10, 2) @default(0.00)
  paymentStatus      PaymentStatus @default(PENDING)
  paymentMethod      String?       // UPI, Card, NetBanking
  razorpayOrderId    String?       @unique
  razorpayPaymentId  String?
  razorpaySignature  String?
  shippingAddress    Json          // Structured: addressLine1, addressLine2, city, state, pincode, contactPhone
  shiprocketOrderId  String?       @unique
  shiprocketShipmentId String?     @unique
  packageWeight      Float         // Combined order weight in grams
  items              OrderItem[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@map("orders")
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal  @db.Decimal(10, 2) // Captured price at purchase time
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("order_items")
}

// VIP Video Consultation Bookings
model StylingConsultation {
  id          String   @id @default(uuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  scheduledAt DateTime
  status      String   @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED
  meetingLink String?  // WebRTC SDK link (Daily.co)
  eventId     String?  // Cal.com / Calendly external ID
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("styling_consultations")
}

// Bridal Trousseau Board (Wishlist)
model TrousseauBoard {
  id          String   @id @default(uuid())
  slug        String   @unique // Cryptographic slug for shareable links
  title       String
  description String?
  brideId     String
  bride       Customer @relation(fields: [brideId], references: [id])
  items       TrousseauItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("trousseau_boards")
}

// Items added to a specific board
model TrousseauItem {
  id        String         @id @default(uuid())
  boardId   String
  board     TrousseauBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  productId String
  product   Product        @relation(fields: [productId], references: [id])
  upvotes   Int            @default(0)
  comments  TrousseauComment[]
  createdAt DateTime       @default(now())
  
  @@unique([boardId, productId])
  @@map("trousseau_items")
}

// Family Member Comments on Trousseau Items
model TrousseauComment {
  id        String        @id @default(uuid())
  itemId    String
  item      TrousseauItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  author    String        // Guest Name
  text      String        @db.Text
  createdAt DateTime      @default(now())
  
  @@map("trousseau_comments")
}
